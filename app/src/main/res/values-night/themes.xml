<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.NumberDrift" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Wooden primary colors -->
        <item name="colorPrimary">#8B5A2B</item>          <!-- Dark wood -->
        <item name="colorPrimaryVariant">#6F4518</item>   <!-- Deeper wood -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary accent (light wood highlight) -->
        <item name="colorSecondary">#C89F72</item>
        <item name="colorSecondaryVariant">#A67C52</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="WoodDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">

        <item name="backgroundTint">#F2E5D5</item> <!-- light wood -->

        <item name="colorPrimary">#8B5A2B</item>

    </style>
</resources>